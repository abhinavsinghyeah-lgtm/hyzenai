GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
PORT=3000

# Semantic memory (optional — if set, enables embedding-based retrieval)
OPENAI_API_KEY=your_openai_api_key_here

# Hybrid scoring weights (must be numbers, default 0.5 each)
KEYWORD_WEIGHT=0.5
SEMANTIC_WEIGHT=0.5

# Set to true to log retrieval scores and embedding debug info
DEBUG=false
